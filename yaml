name: Market Auto Signal
on:
  schedule:
    - cron: '*/10 * * * *' # Har 10 min mein scan karega
  workflow_dispatch: # Manual button se bhi chala sakte hain

jobs:
  run-bot:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v2
      - name: Install Python
        uses: actions/setup-python@v2
        with:
          python-version: '3.9'
      - name: Install Libraries
        run: pip install yfinance pandas-ta requests
      - name: Execute Script
        env:
          TELEGRAM_TOKEN: ${{ secrets.TELEGRAM_TOKEN }}
          CHAT_ID: ${{ secrets.CHAT_ID }}
        run: python bot.py
        
        
