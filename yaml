async function updateLivePrice() {
    try {
        // NIFTY 50 ka ticker yfinance mein ^NSEI hai
        const response = await fetch('http://localhost:8000/get-price/^NSEI');
        const data = await response.json();

        if (data.price) {
            // UI elements update karein
            document.getElementById('main-price').innerText = `₹${data.price}`;
            document.getElementById('sheet-price').innerText = `₹${data.price}`;
            
            // Profit/Loss color logic
            const color = data.p_change >= 0 ? "#22c55e" : "#ef4444";
            document.getElementById('price-change').style.color = color;
            document.getElementById('price-change').innerText = 
                `${data.change > 0 ? '+' : ''}${data.change} (${data.p_change}%)`;
        }
    } catch (error) {
        console.log("Error fetching data:", error);
    }
}

// Har 2 second mein price refresh karein (Real-time feel)
setInterval(updateLivePrice, 2000);

  
        
